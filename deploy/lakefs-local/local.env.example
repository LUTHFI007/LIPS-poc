# Shape of local.env — the credentials file for the local lakeFS + MinIO stack.
#
# You normally never write this by hand: running ./setup.sh generates a real
# local.env automatically (random values, via Python's `secrets` module) the
# first time, and never overwrites it on later runs. This example exists only
# as reference — e.g. if local.env is ever lost and you need to recreate one
# manually, or you just want to see its shape before running setup.sh.
#
# local.env itself is gitignored and must never be committed.

MINIO_ROOT_USER=lips-minio
MINIO_ROOT_PASSWORD=REPLACE_WITH_RANDOM_VALUE
LAKEFS_ACCESS_KEY_ID=AKIALIPSREPLACEWITHRANDOMHEX
LAKEFS_SECRET_ACCESS_KEY=REPLACE_WITH_RANDOM_VALUE
LAKEFS_ENCRYPT_SECRET=REPLACE_WITH_RANDOM_VALUE
