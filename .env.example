# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# main.py loads it at startup via python-dotenv. On a deployed HF Space there is
# no .env — set these as Space secrets instead.

# Neon Postgres connection string — where user/admin accounts (app_users table)
# are stored. Use the SAME value as your MLflow Space's MLFLOW_BACKEND_STORE_URI
# (same database, separate table). Must start with postgresql:// and, for Neon,
# end with ?sslmode=require.
APP_DB_URI=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Comma-separated emails that get the admin role (checked at register AND login).
ADMIN_EMAILS=admin@example.com

# REQUIRED: the app's MLflow client AND the scoreboard read/write through this
# tracking Space (Neon-backed). There is no local sqlite fallback anymore.
MLFLOW_TRACKING_URI=https://<your-mlflow-space>.hf.space

# REQUIRED for the admin "hard delete run" feature when MLFLOW_TRACKING_URI is an
# HTTP Space (the app cannot reach that server's backend indirectly). Set this to
# the EXACT SAME connection string your MLflow Space uses as its
# MLFLOW_BACKEND_STORE_URI secret — that is the database the scoreboard runs live
# in, so deletes must target it. (Not needed if MLFLOW_TRACKING_URI is itself a
# direct postgres:// URI — then it is already the backend.)
MLFLOW_BACKEND_STORE_URI=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# REQUIRED for dataset versioning (private/evaluation data — see
# deploy/lakefs-local/). Run deploy/lakefs-local/setup.sh then start.sh; it
# prints these three values (also readable afterwards from
# deploy/lakefs-local/local.env).
LAKEFS_ENDPOINT=http://127.0.0.1:8000
LAKEFS_ACCESS_KEY_ID=AKIALIPS...
LAKEFS_SECRET_ACCESS_KEY=...
